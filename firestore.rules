rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for user authentication check
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is the owner of a document/profile
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // 1. Users profiles and nested subcollections (notes, scenes, tasks, settings, training, etc.)
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
      
      // All user subcollections (e.g. users/{userId}/notes)
      match /{allSubcollections=**} {
        allow read, write: if isAuth();
      }
    }

    // 2. Relationships pairing and checklist subcollections (checklist, checklistCustom, checklistTemplate)
    match /relationships/{relationshipId} {
      allow read, write: if isAuth();
      
      // CRITICAL FIX: Permit reading/writing BDSM checklist subcollections recursively
      match /{allSubcollections=**} {
        allow read, write: if isAuth();
      }
    }
    
    // 3. Toy Vault V2 subcollections and data paths
    match /data/{relationshipId}/{allSubcollections=**} {
      allow read, write: if isAuth();
    }
  }
}
